ioreg -rn AppleSmartBattery | awk '/AdapterDetails/{v=$0; gsub(/.*"AdapterVoltage"=/,"",v); gsub(/[^0-9].*/,"",v); c=$0; gsub(/.*"Current"=/,"",c); gsub(/[^0-9].*/,"",c)} /"CycleCount" = /{cy=$NF} /"DesignCapacity" = /{if(!d)d=$NF} /"NominalChargeCapacity" = /{n=$NF} END{printf "⚡ %.1fW  🔋 %s cycles  %.1f%% health\n", v*c/1000000, cy, n*100/d}'
